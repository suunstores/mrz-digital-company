{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    }
  ],
"rewrites": [
  {
    "source": "/dashboard",
    "destination": "/"
  },
  {
    "source": "/checklist",
    "destination": "/"
  },
  {
    "source": "/jadwal",
    "destination": "/"
  },
  {
    "source": "/catatan",
    "destination": "/"
  },
  {
    "source": "/p/:slug",
    "destination": "/"
  },
  {
    "source": "/go/:slug",
    "destination": "/"
  },
  {
    "source": "/course/:slug",
    "destination": "/"
  }
]
}
